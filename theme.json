          "gradient": "linear-gradient(to right, #00571a, transparent)"
        },
        {
          "name": "Dark to transparent",
          "slug": "dark-to-transparent",
          "gradient": "linear-gradient(to bottom, rgba(15, 23, 42, 0.8), transparent)"
        }
      ]

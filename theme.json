    "border": {
      "radius": true
    },
    "dimensions": {
      "aspectRatio": true
    }
  },
  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#0f172a"
    },
    "typography": {
      "fontFamily": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "fontSize": "1rem",
      "fontWeight": "400",
      "lineHeight": "1.6"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontSize": "3.75rem",
          "fontWeight": "900",
          "lineHeight": "1.1",
          "letterSpacing": "-0.025em"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "1.875rem",
          "fontWeight": "900",
          "lineHeight": "1.2",
          "letterSpacing": "-0.025em"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "1.125rem",
          "fontWeight": "900",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "1rem",
          "fontWeight": "700"
        }
      },
      "a": {
        "color": {
          "text": "#00571a"
        }
      },
      "button": {
        "color": {
          "background": "#00571a",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "700"
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "#00571a",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "700"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "2rem",
            "bottom": "1rem",
            "left": "2rem"
          }
        }
      },
      "core/heading": {
        "typography": {
          "fontWeight": "900",
          "letterSpacing": "-0.025em"
        }
      },
      "core/paragraph": {
        "typography": {
          "lineHeight": "1.625"
        }
      },
      "core/list": {
        "spacing": {
          "margin": {
            "top": "1rem",
            "bottom": "1rem"
          }
        }
      },
      "woocommerce/product-gallery": {
        "spacing": {
          "margin": {
            "top": "0",
            "right": "0",
            "bottom": "1.5rem",
            "left": "0"
          }
        }
      },
      "woocommerce/product-image": {
        "spacing": {
          "margin": {
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          }
        }
      },
      "woocommerce/product-price": {
        "typography": {
          "fontSize": "1.25rem",
          "fontWeight": "900"
        },
        "color": {
          "text": "#00571a"
        }
      },
      "woocommerce/product-title": {
        "typography": {
          "fontSize": "1.125rem",
          "fontWeight": "700"
        }
      },
      "woocommerce/product-button": {
        "color": {
          "background": "#00571a",
          "text": "#ffffff"
        },
        "typography": {
          "fontWeight": "700"
        }
      },
      "woocommerce/product-rating": {
        "color": {
          "text": "#f59e0b"
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
